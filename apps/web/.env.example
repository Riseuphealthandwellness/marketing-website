# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://riseupwv.org
NEXT_PUBLIC_SITE_NAME=RiseUpWV
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=

# ─── Auth (NextAuth / Auth.js v5) ────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — create credentials at https://console.cloud.google.com/
# Authorized redirect URI: https://riseupwv.org/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated list of allowed email domains (leave blank to allow any Google account)
# Example: riseupwv.org,riseupwv.com
AUTH_ALLOWED_DOMAINS=

# Required in production when running behind a reverse proxy / Cloud Run
AUTH_TRUST_HOST=true

# ─── Sanity CMS ──────────────────────────────────────────────────────────────
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01
SANITY_REVALIDATE_SECRET=
# URL of the Sanity Studio (used for quick-links on the Studio dashboard)
SANITY_STUDIO_URL=

# ─── Integrations ────────────────────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=
RESEND_API_KEY=
CONTACT_TO_EMAIL=
REFERRAL_TO_EMAIL=

# ─── Patient access (external links) ─────────────────────────────────────────
PATIENT_PORTAL_URL=
SCHEDULING_URL=
INTAKE_URL=
REFERRAL_URL=

# ─── Analytics ───────────────────────────────────────────────────────────────
ANALYTICS_PROVIDER=none
